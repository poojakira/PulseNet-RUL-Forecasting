# PulseNet — Production-Ready Environment Configuration
# Copy this to .env and fill in ALL values before starting service
# NEVER commit .env to version control

# --- Security & Encryption (REQUIRED) ---
# Generate encryption key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PULSENET_ENCRYPTION_KEY=

# JWT authentication secret (REQUIRED, >= 32 chars)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
PULSENET_JWT_SECRET=

# Admin password hash (bcrypt)
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
PULSENET_ADMIN_PASSWORD_HASH=

# --- API Configuration ---
PORT=8000
HOST=0.0.0.0
PULSENET_ENV=production
PULSENET_LOG_LEVEL=INFO

# --- Hardware & Training ---
# Set to 'gloo' for Windows or 'nccl' for Linux
PULSENET_DDP_BACKEND=gloo
NUM_GPUS=0

# --- Persistence ---
PULSENET_LEDGER_PATH=blackbox_ledger.json
PULSENET_DATA_DIR=./data
PULSENET_OUTPUT_DIR=./outputs

# --- MLOps ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- CORS Origins (REQUIRED for production) ---
# Comma-separated list, NO wildcards in production
# Example: https://your-api.domain.com,https://dashboard.domain.com
CORS_ORIGINS=

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60