# ============================================================
# PulseNet — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- Security (REQUIRED for production) ---
# Generate encryption key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PULSENET_ENCRYPTION_KEY=

# Generate a strong random secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
PULSENET_JWT_SECRET=

# --- Environment ---
PULSENET_ENV=development          # development | production
PULSENET_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# --- API ---
PORT=8000
HOST=0.0.0.0

# --- Data ---
PULSENET_DATA_DIR=./data
PULSENET_OUTPUT_DIR=./outputs

# --- MLOps (optional) ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- GPU (optional) ---
# Number of GPUs for DDP training (0 = CPU only)
NUM_GPUS=0
