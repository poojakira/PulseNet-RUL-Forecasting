# PulseNet Enterprise Configuration
# Copy this to .env and fill in the values

# Security & Encryption
# Generate a key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PULSENET_ENCRYPTION_KEY=zjQU4grFY77DAijVLkAQKa7pQbSS95LYuO_WL-OaYP4=

# API Configuration
PORT=8000
HOST=0.0.0.0
PULSENET_ENV=development  # Set to 'production' for JSON logging and strict security

# Hardware & Training
# Set to 'gloo' for Windows or 'nccl' for Linux
PULSENET_DDP_BACKEND=gloo
NUM_GPUS=0

# Blockchain Ledger
PULSENET_LEDGER_PATH=ledger.json
