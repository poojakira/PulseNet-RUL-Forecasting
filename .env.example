# PulseNet — Production-Ready Environment Configuration
# Copy this to .env and fill in the values before starting service

# --- Security & Encryption ---
# Generate a key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PULSENET_ENCRYPTION_KEY=your-encryption-key-here

# JWT authentication secret (REQUIRED, >=32 chars; startup fails without it).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PULSENET_JWT_SECRET=your-jwt-secret-here

# --- Credentials store ---
# Preferred: path to a JSON file mounted from a secret manager (Vault / AWS
# Secrets Manager / K8s secret). Keeps credentials out of the process env,
# which leaks via /proc, crash dumps and CI logs.
# PULSENET_USERS_FILE=/run/secrets/pulsenet_users.json
# Discouraged (env var) fallback:
# PULSENET_USERS={"admin": {"hashed_password": "<bcrypt>", "role": "admin"}}

# --- Host / CORS hardening ---
# Comma-separated allowed Host headers (TrustedHostMiddleware). REQUIRED in prod.
# PULSENET_ALLOWED_HOSTS=api.example.com,pulsenet.internal
# CORS origins are configured in config.yaml (api.cors_origins). Deny-by-default.

# --- Metrics endpoint auth ---
# If set, /metrics requires this static bearer token (for Prometheus scrapers).
# Otherwise /metrics requires an admin JWT.
# PULSENET_METRICS_TOKEN=change-me-long-random-token

# --- Distributed rate limiting ---
# Enables shared, cross-replica rate limiting. Without it, limiting is
# per-process only and bypassable across replicas.
# PULSENET_REDIS_URL=redis://redis:6379/0

# --- Audit ledger tamper-evidence ---
# HMAC key so an attacker with file access cannot re-forge the hash chain.
# PULSENET_LEDGER_HMAC_KEY=change-me-long-random-key

# --- Model artifact integrity pins (SHA-256) ---
# Verified before deserializing model/scaler (arbitrary-code-exec defense).
# Provide via env or a sidecar <artifact>.sha256 file. Required in production.
# PULSENET_ISOLATION_FOREST_SHA256=<hex>
# PULSENET_SCALER_SHA256=<hex>

# --- API Configuration ---
PORT=8000
HOST=0.0.0.0
PULSENET_ENV=development  # development | production
PULSENET_LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR

# --- Hardware & Training ---
# Set to 'gloo' for Windows or 'nccl' for Linux
PULSENET_DDP_BACKEND=gloo
NUM_GPUS=0

# --- Persistence ---
# Path to the immutable blockchain ledger
PULSENET_LEDGER_PATH=blackbox_ledger.json
PULSENET_DATA_DIR=./data
PULSENET_OUTPUT_DIR=./outputs

# --- MLOps ---
MLFLOW_TRACKING_URI=http://localhost:5000
