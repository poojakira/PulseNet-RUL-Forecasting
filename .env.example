# ============================================================
# PulseNet — Environment Variables
# ============================================================
# Copy this file to .env and fill in values for your environment.
# All variables can also be set directly in your shell or CI/CD.

# --- Security ---
# JWT secret for API authentication (CHANGE THIS in production!)
PULSENET_JWT_SECRET=change-me-in-production

# AES-256 encryption key (auto-generated if empty)
PULSENET_ENCRYPTION_KEY=

# --- API ---
# FastAPI host and port
PULSENET_API_HOST=0.0.0.0
PULSENET_API_PORT=8000

# --- Dashboard ---
# Streamlit host and port
PULSENET_DASHBOARD_HOST=0.0.0.0
PULSENET_DASHBOARD_PORT=8501

# --- MLOps ---
# MLflow tracking URI (local directory or remote server)
MLFLOW_TRACKING_URI=mlruns

# --- GPU / NVIDIA ---
# Visible GPU devices (comma-separated IDs or "all")
NVIDIA_VISIBLE_DEVICES=all

# NCCL debug level for distributed training
NCCL_DEBUG=INFO

# --- Python ---
PYTHONPATH=src
